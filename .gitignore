# ============================================
# PROJECT SPECIFIC - Psychologist AI
# ============================================

# Large datasets (never commit raw data)
data/*/train/
data/*/val/
data/*/test/
data/**/*.jpg
data/**/*.png
data/**/*.wav
data/**/*.mp3
data/**/*.mp4

# Ignore CSVs/JSONs in raw dataset folders. Do not commit user data.
data/**/*.csv
!data/demo_memory/*.csv
!data/test_memory/*.csv

data/**/*.json
!data/demo_memory/*.json
!data/test_memory/*.json
!data/voice_emotion/dataset_metadata.json

# CRITICAL: Always ignore real user data
data/user_memory/
assets/reports/psv_visualizations/
logs/

# Personal documentation and reference files
ULTRA_TECHNICAL_REFERENCE.md
INTERVIEW_PREPARATION_GUIDE.md

# Feature cache — generated at runtime, never commit
data/voice_emotion/feature_cache/

# Trained models (too large for git)
models/*.pth
models/*.h5
models/*.pkl
models/*.onnx

# Keep only config files in models/
!models/*_config.json
!models/*_labels.json
!models/README.md

# Training outputs
reports/*.png
reports/*.jpg
reports/*.pdf
reports/training_history_*.json

# Temporary files
*.tmp
*.swp
*~

# Wandb experiment tracking
wandb/

# Tensorboard logs
runs/
logs/

# Mac
.DS_Store